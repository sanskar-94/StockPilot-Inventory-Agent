# ─────────────────────────────────────────────────────────────
# StockPilot environment.  Copy to ".env" and fill in real values.
# Demo mode (CSV) needs NONE of these. They are only for the
# connected/live path (NIM reasoning, Shopify, Slack via n8n).
# ─────────────────────────────────────────────────────────────

# ── API 2: NVIDIA NIM (the reasoning + writing layer) ──────────
# Get a key at https://build.nvidia.com  (free tier).
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NIM_URL=https://integrate.api.nvidia.com/v1/chat/completions
NIM_MODEL=meta/llama-3.1-70b-instruct

# ── Fallback provider (any OpenAI-style /chat/completions) ──────
# Used automatically when NIM rate-limits (429) or times out.
# Examples: OpenAI, Groq, Together, OpenRouter. Leave blank to skip.
FALLBACK_API_KEY=
FALLBACK_URL=https://api.openai.com/v1/chat/completions
FALLBACK_MODEL=gpt-4o-mini

# ── API service ────────────────────────────────────────────────
STOCKPILOT_API_HOST=0.0.0.0
STOCKPILOT_API_PORT=8000

# ── API 1: Shopify Admin (only used by the n8n nodes, not Python)
# Configure these as n8n credentials, not here, but documented for clarity.
# SHOPIFY_STORE=your-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxx

# ── API 3: Slack (only used by the n8n nodes, not Python) ───────
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
# SLACK_CHANNEL=#inventory
